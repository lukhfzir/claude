"dimensions.md:Dimensions"
"measures.md:Measures"
"warehouse.md:Data Warehouse"
"architecture_decisions.md:Analytics ADR"
"changelog.md:Analytics Changelog"
)

for item in "${FILES[@]}"; do
    IFS=":" read -r file title <<< "$item"
    create "$file" "$title"
done

echo "Enterprise analytics framework created."
