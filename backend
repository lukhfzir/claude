create "architecture_decisions.md" "Architecture Decision Records"
create "known_issues.md" "Known Issues"
create "tech_debt.md" "Technical Debt"
create "runbooks.md" "Operational Runbooks"
create "changelog.md" "Backend Changelog"

cat > BACKEND_AGENT.md <<'EOF'
# Backend Agent Instructions

Before making changes:

1. Read:
   - backend/index.md
   - backend/architecture.md
   - backend/system_overview.md
   - backend/business_rules.md
   - backend/api_contracts.md
   - backend/service_catalog.md
   - backend/domain_model.md
   - backend/architecture_decisions.md
   - backend/security.md
   - backend/known_issues.md
   - backend/tech_debt.md

2. Validate:
   - Existing APIs
   - Existing business rules
   - Existing services
   - Existing events
   - Existing integrations

3. Never:
   - Break API compatibility
   - Duplicate business logic
   - Duplicate endpoints
   - Bypass authentication
   - Ignore validation rules
   - Remove logging
   - Remove monitoring

4. Every feature must update:
   - endpoints.md
   - api_contracts.md
   - changelog.md
   - service_catalog.md
   - architecture.md (if needed)

5. Every API change must document:
   - Request schema
   - Response schema
   - Errors
   - Permissions
   - Version impact

6. Every service change must document:
   - Dependencies
   - Events
   - Queues
   - External integrations

7. Keep changes consistent with existing architecture unless explicitly instructed otherwise.
EOF

echo "Enterprise backend framework created."
